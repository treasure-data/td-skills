#   ROUND(100.0 * COUNT(DISTINCT CASE WHEN email_marketing_consent = 'given' THEN customer_id END) / COUNT(DISTINCT customer_id), 2) AS email_opt_in_rate,
#   COUNT(DISTINCT CASE WHEN consent_updated_at < CAST(EXTRACT(EPOCH FROM NOW() - INTERVAL '24' MONTH) AS BIGINT) THEN customer_id END) AS expired_consents
# FROM customer_db.consent_wide

